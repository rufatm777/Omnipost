# =====================================================
# OmniPost v3 — Netlify Deployment
# =====================================================
# Add ALL of these in Netlify Dashboard:
# Site configuration → Environment variables
# =====================================================

# ─── CLAUDE AI ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# ─── APP URL ─────────────────────────────────────────
# Change after deploy to: https://your-site-name.netlify.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── TWITTER / X ─────────────────────────────────────
# Callback URL: {NEXT_PUBLIC_APP_URL}/api/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─── META (Facebook + Instagram + Threads) ───────────
# Facebook+Instagram callback: {NEXT_PUBLIC_APP_URL}/api/auth/meta/callback
# Threads callback: {NEXT_PUBLIC_APP_URL}/api/auth/threads/callback
# (Both use the same Meta app, but different redirect URIs)
META_APP_ID=
META_APP_SECRET=

# ─── LINKEDIN ────────────────────────────────────────
# Callback URL: {NEXT_PUBLIC_APP_URL}/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── GOOGLE (YouTube) ────────────────────────────────
# Callback URL: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── TIKTOK ──────────────────────────────────────────
# Callback URL: {NEXT_PUBLIC_APP_URL}/api/auth/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── TELEGRAM ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ─── TOKEN STORAGE (for Netlify persistence) ────────
# After connecting accounts locally, copy data/tokens.json
# content here as a single-line JSON string:
# OMNIPOST_TOKENS={"twitter":{"platform":"twitter","access_token":"xxx"},...}
